# Copy to `.env` and load before running (optional). Example:
#   set -a && source .env && set +a && python run_pantryflow.py

# Single URL you give users for the Streamlit web app (any modern browser).
# Local (default when using run_pantryflow.py): http://127.0.0.1:8501
# Production (Streamlit Community Cloud, your domain, etc.):
#   PUBLIC_APP_URL=https://your-app.streamlit.app

# PUBLIC_APP_URL=http://127.0.0.1:8501

# Streamlit server port (run_pantryflow pins this; match PUBLIC_APP_URL if you set it).
# STREAMLIT_PORT=8501

# FastAPI base URL for the Streamlit UI to call (see README).
# BACKEND_URL=http://127.0.0.1:8000

# API listen port for run_pantryflow.py / local Uvicorn. Change if 8000 is already in use.
# API_PORT=8001

# LAN dev (phone/tablet browser on same Wi‑Fi): allow CORS from http://<LAN-IP>:8501 etc.
# Do not enable in production. See backend app.core.config.dev_cors_origin_regex.
# SMART_PANTRY_DEV_CORS_REGEX=1
