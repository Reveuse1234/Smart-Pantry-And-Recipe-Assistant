# Copy into Streamlit Cloud → App settings → Secrets (not committed).
# Use your real Render URL and .streamlit.app hostname.

BACKEND_URL = "https://YOUR-SERVICE.onrender.com"
PUBLIC_APP_URL = "https://YOUR-APP-NAME.streamlit.app"
PANTRY_SECRET = "same-long-secret-as-on-render"
CORS_ORIGINS = "https://YOUR-APP-NAME.streamlit.app"
